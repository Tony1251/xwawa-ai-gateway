# ============================================================
# Xwawa AI Gateway - Environment Variables Template
# ============================================================
# 复制为 .env 并填入真实值。
# 生产环境强烈建议使用 secrets manager (Vault / AWS SM / K8s Secret)
# ============================================================

# === Service ===
APP_NAME=Xwawa-AI-Gateway
APP_ENV=development                          # development | staging | production
APP_DEBUG=true                               # 生产必须 false
APP_HOST=0.0.0.0
APP_PORT=8800
APP_SECRET_KEY=CHANGE_ME_64_HEX_CHARS        # python -c "import secrets; print(secrets.token_hex(32))"
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# === Database ===
DATABASE_URL=postgresql+asyncpg://xwawa:xwawa@localhost:5432/xwawa
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false                           # 生产必须 false

# === Redis ===
REDIS_URL=redis://:redis@localhost:6379/0

# === Upstream Providers (真实密钥) ===
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=https://api.anthropic.com

MIDJOURNEY_API_KEY=...
MIDJOURNEY_BASE_URL=https://api.midjourney.com/v1

DOUBAO_API_KEY=...
MINIMAX_API_KEY=your-minimax-api-key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

DEEPSEEK_API_KEY=...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === Billing ===
MARKUP_RATE=1.30         # 加价 30%（上游成本 → 用户付费）
TAX_RATE=0.06            # 增值税 6%

# === Risk Control ===
RISK_DAILY_LIMIT_DEFAULT=10.00       # 默认每日额度 ¥10
RISK_PER_CALL_LIMIT_DEFAULT=0.50     # 默认单次额度 ¥0.5
RISK_LOCKOUT_THRESHOLD=5             # 5 次异常 → 锁定账号
RISK_RATE_LIMIT_PER_MIN=60           # 每分钟最大调用次数

# === KYC (走第三方) ===
KYC_PROVIDER=alipay                   # alipay | wechat | custom
ALIPAY_APP_ID=...
ALIPAY_PRIVATE_KEY=...
ALIPAY_PUBLIC_KEY=...

# === Rate Limit (Redis-backed) ===
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_TOKENS_PER_MINUTE=100000

# === Observability ===
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                       # json | console
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# === Security ===
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
BCRYPT_ROUNDS=12                      # 密码哈希强度 (10-14 推荐)
API_KEY_LENGTH=43                     # 生成的 API Key 长度

# === Postgres (docker-compose) ===
POSTGRES_USER=xwawa
POSTGRES_PASSWORD=xwawa               # 改用 secrets.token_urlsafe(32)
POSTGRES_DB=xwawa

# === Grafana ===
GRAFANA_PASSWORD=admin                # 改用 secrets.token_urlsafe(16)